generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Role {
  user
  admin
}

enum AuditAction {
  create
  update
  delete
  rollback
}

enum EntityType {
  bug
  patch
  verification
  user
}

enum CreditEventType {
  signup
  search
  patch_submitted
  bug_reported
  duplicate_penalty
  verification_given
  patch_verified_fixed
  patch_verified_not_fixed
}

enum Severity {
  low
  medium
  high
  critical
}

enum BugStatus {
  open
  confirmed
  patched
  closed
}

enum VerificationOutcome {
  fixed
  not_fixed
  partial
}

enum BugAccuracy {
  accurate
  inaccurate
}

enum BugCategory {
  crash
  build
  types
  performance
  behavior
  config
  compatibility
  install
}

model User {
  id             String   @id @default(uuid())
  githubUsername  String   @unique
  clerkId        String?  @unique
  avatarUrl      String?
  credits        Int      @default(5)
  role           Role     @default(user)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bugs               Bug[]
  patches            Patch[]
  verifications      Verification[]
  patchAccesses      PatchAccess[]
  creditTransactions CreditTransaction[]
  auditLogs          AuditLog[]
}

model CreditTransaction {
  id        String          @id @default(uuid())
  amount    Int
  type      CreditEventType
  balance   Int

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  relatedBugId   String?
  relatedPatchId String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Bug {
  id               String       @id @default(uuid())
  title            String?
  description      String?
  library          String
  version          String
  ecosystem        String
  severity         Severity     @default(low)
  status           BugStatus    @default(open)
  tags             String[]
  embedding        Unsupported("vector(1536)")?
  errorMessage     String?
  errorCode        String?
  stackTrace       String?
  fingerprint      String?
  triggerCode      String?
  expectedBehavior String?
  actualBehavior   String?
  context          Json?
  contextLibraries String[]
  runtime          String?
  platform         String?
  category         BugCategory?
  accessCount      Int          @default(0)
  searchHitCount   Int          @default(0)

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  patches   Patch[]
  revisions BugRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([library, version])
  @@index([ecosystem])
  @@index([status])
  @@index([reporterId])
  @@index([fingerprint])
}

model Patch {
  id                String  @id @default(uuid())
  explanation       String  @map("description")
  code              String?
  steps             Json?
  score             Int     @default(0)
  versionConstraint String?

  bugId String
  bug   Bug    @relation(fields: [bugId], references: [id], onDelete: Cascade)

  submitterId String
  submitter   User   @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  verifications Verification[]
  patchAccesses PatchAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bugId])
  @@index([submitterId])
}

model Verification {
  id            String              @id @default(uuid())
  outcome       VerificationOutcome
  note          String?
  errorBefore   String?
  errorAfter    String?
  testedVersion String?
  bugAccuracy   BugAccuracy         @default(accurate)

  patchId    String
  patch      Patch  @relation(fields: [patchId], references: [id], onDelete: Cascade)

  verifierId String
  verifier   User   @relation(fields: [verifierId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([patchId, verifierId])
  @@index([patchId])
  @@index([verifierId])
}

model PatchAccess {
  id        String   @id @default(uuid())

  patchId   String
  patch     Patch    @relation(fields: [patchId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([patchId, userId])
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType EntityType
  entityId   String
  changes    Json?
  metadata   Json?
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model BugRevision {
  id          String      @id @default(uuid())
  version     Int
  action      AuditAction
  title       String
  description String
  severity    Severity
  status      BugStatus
  tags        String[]
  snapshot    Json?
  bugId       String
  bug         Bug         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  actorId     String
  createdAt   DateTime    @default(now())

  @@unique([bugId, version])
  @@index([bugId, createdAt])
}
