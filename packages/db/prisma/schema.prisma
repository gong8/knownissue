generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum Role {
  user
  admin
}

enum AuditAction {
  create
  update
  delete
  rollback
}

enum EntityType {
  bug
  patch
  review
  user
}

enum ReviewTargetType {
  bug
  patch
}

enum CreditEventType {
  signup
  search
  patch_submitted
  patch_upvoted
  patch_downvoted
  bug_reported
  duplicate_penalty
  review_given
  bug_upvoted
  bug_downvoted
}

model User {
  id             String   @id @default(uuid())
  githubUsername  String   @unique
  clerkId        String?  @unique
  avatarUrl      String?
  credits        Int      @default(5)
  role           Role     @default(user)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bugs               Bug[]
  patches            Patch[]
  reviews            Review[]
  creditTransactions CreditTransaction[]
  auditLogs          AuditLog[]
}

model CreditTransaction {
  id        String          @id @default(uuid())
  amount    Int
  type      CreditEventType
  balance   Int

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  relatedBugId   String?
  relatedPatchId String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

enum Severity {
  low
  medium
  high
  critical
}

enum BugStatus {
  open
  confirmed
  patched
  closed
}

model Bug {
  id               String    @id @default(uuid())
  title            String?
  description      String?
  library          String
  version          String
  ecosystem        String
  severity         Severity  @default(low)
  status           BugStatus @default(open)
  tags             String[]
  embedding        Unsupported("vector(1536)")?
  errorMessage     String?
  errorCode        String?
  stackTrace       String?
  fingerprint      String?
  triggerCode      String?
  expectedBehavior String?
  actualBehavior   String?
  relatedLibraries Json?
  environment      Json?
  score            Int       @default(0)

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  patches   Patch[]
  revisions BugRevision[]
  reviews   Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([library, version])
  @@index([ecosystem])
  @@index([status])
  @@index([reporterId])
  @@index([fingerprint])
}

enum Vote {
  up
  down
}

model Patch {
  id                String  @id @default(uuid())
  explanation       String  @map("description")
  code              String?
  steps             Json?
  score             Int     @default(0)
  versionConstraint String?

  bugId String
  bug   Bug    @relation(fields: [bugId], references: [id], onDelete: Cascade)

  submitterId String
  submitter   User   @relation(fields: [submitterId], references: [id], onDelete: Cascade)

  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bugId])
  @@index([submitterId])
}

model Review {
  id         String            @id @default(uuid())
  vote       Vote
  note       String?           @map("comment")
  targetId   String?
  targetType ReviewTargetType?
  version    String?

  patchId String?
  patch   Patch?  @relation(fields: [patchId], references: [id], onDelete: Cascade)

  bugId String?
  bug   Bug?   @relation(fields: [bugId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patchId, reviewerId])
  @@unique([targetId, targetType, reviewerId])
}

model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  entityType EntityType
  entityId   String
  changes    Json?
  metadata   Json?
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model BugRevision {
  id          String      @id @default(uuid())
  version     Int
  action      AuditAction
  title       String
  description String
  severity    Severity
  status      BugStatus
  tags        String[]
  snapshot    Json?
  bugId       String
  bug         Bug         @relation(fields: [bugId], references: [id], onDelete: Cascade)
  actorId     String
  createdAt   DateTime    @default(now())

  @@unique([bugId, version])
  @@index([bugId, createdAt])
}
